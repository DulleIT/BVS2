[200~# Basis-Image mit Python 3.11 (leichtgewichtig)
FROM python:3.11-slim

# Arbeitsverzeichnis im Container
WORKDIR /app

# Systemabhängigkeiten installieren (optional, falls benötigt)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
 && rm -rf /var/lib/apt/lists/*

# requirements.txt kopieren und Python-Abhängigkeiten installieren
COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

# gesamten Code kopieren
COPY . .

# Standardbefehl (kann in docker-compose überschrieben werden)
CMD ["python", "ex_09_api_server.py"]

